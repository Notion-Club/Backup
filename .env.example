# Supabase — projet Notivault dédié (nouveau modèle de clés, pas de legacy).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Clé publishable (client + SSR, RLS appliquée) — sb_publishable_…
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Clé secret (serveur uniquement, bypass RLS) — sb_secret_… NE PAS exposer au client.
SUPABASE_SECRET_KEY=

# Optionnel : URL publique de l'app (sinon dérivée des headers de la requête).
# Utile pour les liens e-mail en preview/prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OAuth (M2b / M2c) ─────────────────────────────────────────────
# Secret de signature HMAC des états OAuth (anti-CSRF). Générer une valeur
# aléatoire longue (ex. openssl rand -hex 32).
OAUTH_STATE_SECRET=

# ── Notion OAuth (M2b) — intégration publique ────────────────────
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
# Doit être identique au caractère près à l'URI enregistrée chez Notion.
NOTION_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/notion/callback

# ── GitHub App (M2c) ─────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# Clé privée PEM de l'App (retours à la ligne échappés en \n).
GITHUB_APP_PRIVATE_KEY=
# Setup URL de l'App côté GitHub : http://localhost:3000/api/oauth/github/callback
